# GCP project. Fill in after project provisioning.
GCP_PROJECT_ID=""
GCP_REGION="asia-northeast1"

# Vertex AI custom endpoint. Fill in after model deployment.
VERTEX_ENDPOINT_ID=""
VERTEX_ENDPOINT_LOCATION="asia-northeast1"
VERTEX_PREDICTION_TIMEOUT=30

# Gemini
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_TIMEOUT=15

# Veo. Bucket name is undecided and should be added later.
VEO_MODEL="veo-3.1-fast"
VEO_TIMEOUT=300
VEO_POLLING_INTERVAL=5
GCS_BUCKET_NAME=""
GCS_SIGNED_URL_EXPIRATION_HOURS=1

# Firestore
FIRESTORE_DATABASE_ID="(default)"

# Bandit
BANDIT_UCB_ALPHA=1.0

# App
ENVIRONMENT="development"
LOG_LEVEL="INFO"
